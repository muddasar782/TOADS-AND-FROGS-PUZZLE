# PUZZLE LOGIC

def make_initial(n):  return ['T']*n + ['_'] + ['F']*n
def make_goal(n):     return ['F']*n + ['_'] + ['T']*n

def legal_moves(state):
    moves = []
    empty = state.index('_')
    for i, p in enumerate(state):
        if p == 'T':
            if i+1 == empty:                            moves.append((i, empty))
            if i+2 == empty and state[i+1] == 'F':     moves.append((i, empty))
        elif p == 'F':
            if i-1 == empty:                            moves.append((i, empty))
            if i-2 == empty and state[i-1] == 'T':     moves.append((i, empty))
    return moves

def apply_move(state, frm, to):
    s = state[:]
    s[frm], s[to] = s[to], s[frm]
    return s

def is_won(state, n):  return state == make_goal(n)
def is_stuck(state):   return len(legal_moves(state)) == 0
def optimal_steps(n):  return n*(n+2)

# BFS BRUTE-FORCE SOLVER

def bfs_solve(initial_state, n):
    """
    BFS brute-force algorithm as specified.
    Returns a list of (from_index, to_index) moves, or None if unsolvable.
    """
    goal = make_goal(n)
    queue = deque()
    visited = set()

    # Enqueue (state, path_of_moves)
    queue.append((initial_state[:], []))

    while queue:
        state, path = queue.popleft()

        if state == goal:
            return path

        state_key = tuple(state)
        if state_key in visited:
            continue
        visited.add(state_key)

        empty_pos = state.index('_')

        for i, piece in enumerate(state):
            if piece == 'T':
                # Toad moves right: step 1
                if i + 1 == empty_pos:
                    new_state = state[:]
                    new_state[i], new_state[empty_pos] = new_state[empty_pos], new_state[i]
                    if tuple(new_state) not in visited:
                        queue.append((new_state, path + [(i, empty_pos)]))
                # Toad jumps right over a frog: step 2
                if i + 2 == empty_pos and state[i + 1] == 'F':
                    new_state = state[:]
                    new_state[i], new_state[empty_pos] = new_state[empty_pos], new_state[i]
                    if tuple(new_state) not in visited:
                        queue.append((new_state, path + [(i, empty_pos)]))

            elif piece == 'F':
                # Frog moves left: step 1
                if i - 1 == empty_pos:
                    new_state = state[:]
                    new_state[i], new_state[empty_pos] = new_state[empty_pos], new_state[i]
                    if tuple(new_state) not in visited:
                        queue.append((new_state, path + [(i, empty_pos)]))
                # Frog jumps left over a toad: step 2
                if i - 2 == empty_pos and state[i - 1] == 'T':
                    new_state = state[:]
                    new_state[i], new_state[empty_pos] = new_state[empty_pos], new_state[i]
                    if tuple(new_state) not in visited:
                        queue.append((new_state, path + [(i, empty_pos)]))

    return None  # No solution found

# ANIMATION

class AnimPiece:
    def __init__(self, sx, sy, ex, ey, piece, duration=0.25):
        self.sx, self.sy = sx, sy
        self.ex, self.ey = ex, ey
        self.piece    = piece
        self.duration = duration
        self.t0       = time.time()
        self.done     = False
        self.cx, self.cy = float(sx), float(sy)

    def update(self):
        elapsed = time.time() - self.t0
        p = min(elapsed / self.duration, 1.0)
        p = 1 - (1-p)**3
        self.cx = self.sx + (self.ex - self.sx) * p
        self.cy = self.sy + (self.ey - self.sy) * p
        arc_h = abs(self.ex - self.sx) * 0.18
        self.cy -= arc_h * math.sin(p * math.pi)
        if elapsed >= self.duration:
            self.cx, self.cy = float(self.ex), float(self.ey)
            self.done = True

# CREATURE DRAWING

def _c(surf, color, cx, cy, r, w=0):
    pygame.draw.circle(surf, color, (int(cx), int(cy)), max(1, int(r)), w)

def _e(surf, color, cx, cy, rw, rh, w=0):
    rect = pygame.Rect(int(cx-rw), int(cy-rh), int(rw*2), int(rh*2))
    if rect.width > 0 and rect.height > 0:
        pygame.draw.ellipse(surf, color, rect, w)


def draw_toad(surf, cx, cy, radius, pulse=0.0, selected=False, valid_dest=False):
    r = radius
    s = r / 40.0

    gr = r + 5 + int(3*math.sin(pulse*2))
    gs = pygame.Surface((gr*2+4, gr*2+4), pygame.SRCALPHA)
    a  = 65 + int(25*math.sin(pulse*2))
    pygame.draw.circle(gs, (*TOAD_GLOW, a), (gr+2, gr+2), gr)
    surf.blit(gs, (int(cx)-gr-2, int(cy)-gr-2))

    _e(surf, (0,0,0,80), cx, cy+r*0.75, r*0.7, r*0.18)
    bw, bh = int(r*0.84), int(r*0.70)
    _e(surf, TOAD_DARK,  cx, cy+s*2, bw+3, bh+3)
    _e(surf, TOAD_SKIN,  cx, cy+s*2, bw,   bh)
    _e(surf, TOAD_BELLY, cx, cy+s*9, int(bw*0.55), int(bh*0.44))

    for wx, wy, wr in [(-s*13, -s*4, s*5), (s*11, -s*2, s*4),
                        (-s*5,   s*9, s*3), ( s*7,  s*10, s*3)]:
        _c(surf, TOAD_WART, cx+wx, cy+wy, max(1, wr))

    for side in (-1, 1):
        lx = cx + side*int(r*0.74)
        _e(surf, TOAD_DARK, lx, cy+int(r*0.56), int(s*14), int(s*9))
        _e(surf, TOAD_SKIN, lx, cy+int(r*0.51), int(s*12), int(s*7))
        for toe in range(3):
            tx = lx + side*(int(s*5) + toe*int(s*5) - int(s*5))
            _c(surf, TOAD_SKIN, tx, cy+int(r*0.70), max(1, int(s*4)))

    ey_y = cy - int(r*0.60)
    for side in (-1, 1):
        ex_ = cx + side*int(r*0.30)
        _c(surf, TOAD_DARK,  ex_, ey_y, int(s*11)+2)
        _c(surf, TOAD_EYE,   ex_, ey_y, int(s*11))
        _c(surf, TOAD_PUPIL, ex_+side*int(s*3), ey_y+int(s*2), max(1,int(s*5)))
        _c(surf, (255,255,255), ex_+side*int(s*2)-int(s*2), ey_y-int(s*3), max(1,int(s*2)))

    mr = pygame.Rect(int(cx-s*16), int(cy+s*2), int(s*32), int(s*16))
    if mr.width > 0 and mr.height > 0:
        pygame.draw.arc(surf, TOAD_DARK, mr, math.pi, math.pi*2, max(1,int(s*2)))

    if selected:
        rr = r+7+int(3*math.sin(pulse*3))
        _c(surf, SEL_RING, cx, cy, rr, 3)

    if valid_dest:
        va = int(110+80*math.sin(pulse*4))
        vs = pygame.Surface((r*2+28, r*2+28), pygame.SRCALPHA)
        pygame.draw.circle(vs, (100,220,255,va), (r+14, r+14), r+12)
        surf.blit(vs, (int(cx)-r-14, int(cy)-r-14))
        _c(surf, (100,220,255), cx, cy, r+12, 3)


