def draw_rounded_rect(surf, color, rect, r=12, border=0, bc=None):
    pygame.draw.rect(surf, color, rect, border_radius=r)
    if border and bc:
        pygame.draw.rect(surf, bc, rect, border, border_radius=r)

def draw_button(surf, rect, text, hovered, active=False,
                base_color=None, hover_color=None):
    if base_color is None:  base_color  = BTN_BG
    if hover_color is None: hover_color = BTN_HOV
    col = BTN_ACTIVE if active else (hover_color if hovered else base_color)
    draw_rounded_rect(surf, col, rect, 10, 1, BORDER_CLR)
    lbl = font_btn.render(text, True, TEXT_MAIN)
    surf.blit(lbl, lbl.get_rect(center=rect.center))

def draw_arrow(surf, x1, y1, x2, y2, color, w=2):
    pygame.draw.line(surf, color, (x1,y1), (x2,y2), w)
    angle = math.atan2(y2-y1, x2-x1)
    for da in (0.4, -0.4):
        ax = x2 - 10*math.cos(angle-da)
        ay = y2 - 10*math.sin(angle-da)
        pygame.draw.line(surf, color, (x2,y2), (int(ax),int(ay)), w)

# SPEED CONTROL CONFIG

SPEED_OPTIONS  = [("0.5×", 0.5), ("1×", 1.0), ("2×", 2.0), ("4×", 4.0)]
ANIM_BASE_DUR  = 0.38   # seconds per move at 1× speed

# MAIN GAME CLASS

class Game:
    N_OPTIONS = [1, 2, 3, 4, 5]
    BOARD_Y   = 330

    def __init__(self):
        self.n = 3
        self.auto_speed     = 1.0    # multiplier
        self.auto_speed_idx = 1      # index into SPEED_OPTIONS
        self.reset()
        self._build_ui()

    def reset(self):
        self.state      = make_initial(self.n)
        self.history    = [self.state[:]]
        self.selected   = None
        self.anim       = None
        self.won        = False
        self.stuck      = False
        self.steps      = 0
        self.start_time = time.time()
        self.elapsed    = 0.0
        self.pulse      = 0.0
        self.msg        = ""
        self.msg_timer  = 0.0
        # Auto-solve state
        self.solving        = False   # BFS running / playback active
        self.solve_path     = []      # list of (frm, to) moves
        self.solve_step_idx = 0       # next move index to play
        self.solve_delay    = 0.0     # timer between moves
        self.solve_status   = ""      # status text shown to user

    def _build_ui(self):
        bw, bh = 50, 34
        total_w = len(self.N_OPTIONS)*(bw+8) - 8
        sx = W//2 - total_w//2
        self.n_btns    = [(pygame.Rect(sx+i*(bw+8), 62, bw, bh), v)
                          for i,v in enumerate(self.N_OPTIONS)]
        self.btn_reset = pygame.Rect(W//2-250, 595, 130, 40)
        self.btn_undo  = pygame.Rect(W//2-105, 595, 130, 40)
        self.btn_solve = pygame.Rect(W//2+ 40, 595, 155, 40)

        # Speed buttons (to the right of solve button)
        spd_x = W//2 + 210
        spd_w = 52
        self.speed_btns = [
            (pygame.Rect(spd_x + i*(spd_w+4), 595, spd_w, 40), i)
            for i in range(len(SPEED_OPTIONS))
        ]

    def _cell_layout(self):
        total   = len(self.state)
        radius  = min(46, max(24, (W-120)//(total*2+1)))
        spacing = radius*2 + 14
        ox      = (W - (total*spacing - 14))//2 + radius
        return [(ox + i*spacing, self.BOARD_Y, radius) for i in range(total)]

    def _valid_dests(self):
        if self.selected is None: return []
        return [to for frm,to in legal_moves(self.state) if frm==self.selected]

    def _sources_for_empty(self):
        empty = self.state.index('_')
        return [frm for frm,to in legal_moves(self.state) if to==empty]

    #  Auto-solve 

    def start_solve(self):
        """Run BFS from the current state and start animated playback."""
        if self.won or self.anim:
            return
        self.solving     = True
        self.solve_status = "🔍 BFS searching…"
        self.selected    = None

        path = bfs_solve(self.state, self.n)

        if path is None:
            self.solving      = False
            self.solve_status = ""
            self.show_msg("BFS: No solution found from this state!", 3.0)
            return

        self.solve_path     = path
        self.solve_step_idx = 0
        self.solve_delay    = 0.0
        self.solve_status   = f"🤖 Auto-solving… step 0 / {len(path)}"

    def stop_solve(self):
        self.solving      = False
        self.solve_path   = []
        self.solve_status = ""

    def _advance_solve(self, dt):
        """Called each frame while solving is active."""
        if not self.solving or self.anim:
            return
        if self.solve_step_idx >= len(self.solve_path):
            self.solving      = False
            self.solve_status = ""
            return

        self.solve_delay -= dt
        if self.solve_delay > 0:
            return

        # Play next move
        frm, to = self.solve_path[self.solve_step_idx]
        cells   = self._cell_layout()
        self._do_move(frm, to, cells)
        self.solve_step_idx += 1

        total = len(self.solve_path)
        self.solve_status = f"🤖 Auto-solving… step {self.solve_step_idx} / {total}"

        anim_dur = ANIM_BASE_DUR / self.auto_speed
        # Small pause between moves (0.1 s base, scaled)
        self.solve_delay = anim_dur + (0.10 / self.auto_speed)

        if self.won:
            self.solving      = False
            self.solve_status = ""

    #  Manual interaction

    def handle_click(self, mx, my):
        if self.won or self.stuck or self.anim or self.solving: return
        cells = self._cell_layout()
        hit = None
        for i,(cx,cy,r) in enumerate(cells):
            if math.hypot(mx-cx, my-cy) <= r+6:
                hit = i; break
        if hit is None:
            self.selected = None; return

        piece = self.state[hit]

        if self.selected is not None and hit in self._valid_dests():
            self._do_move(self.selected, hit, cells); return

        if piece == '_':
            srcs = self._sources_for_empty()
            if len(srcs) == 1: self._do_move(srcs[0], hit, cells)
            else:              self.selected = None
            return

        can = any(frm==hit for frm,_ in legal_moves(self.state))
        if can:
            self.selected = hit
        else:
            self.show_msg("This piece has no valid moves!")
            self.selected = None

    def _do_move(self, frm, to, cells):
        anim_dur = ANIM_BASE_DUR / self.auto_speed if self.solving else 0.25
        sx,sy,_ = cells[frm]; ex,ey,_ = cells[to]
        self.anim  = AnimPiece(sx, sy, ex, ey, self.state[frm], duration=anim_dur)
        self.state = apply_move(self.state, frm, to)
        self.history.append(self.state[:])
        self.steps += 1
        self.selected = None
        if is_won(self.state, self.n):   self.won   = True
        elif is_stuck(self.state):       self.stuck = True

    def undo(self):
        if self.solving: self.stop_solve()
        if len(self.history) <= 1 or self.anim: return
        self.history.pop()
        self.state    = self.history[-1][:]
        self.steps    = max(0, self.steps-1)
        self.selected = None
        self.won = self.stuck = False

    def show_msg(self, text, dur=2.5):
        self.msg = text; self.msg_timer = dur

    def update(self, dt):
        self.pulse += dt
        if self.anim:
            self.anim.update()
            if self.anim.done: self.anim = None
        if self.solving:
            self._advance_solve(dt)
        if not self.won and not self.stuck:
            self.elapsed = time.time() - self.start_time
        if self.msg_timer > 0:
            self.msg_timer -= dt
            if self.msg_timer <= 0: self.msg = ""

    # Draw 

    def draw(self, mx, my):
        t = self.pulse
        draw_background(t)
        cells = self._cell_layout()

        # Title 
        ts = font_title.render("TOADS  &  FROGS", True, TEXT_MAIN)
        screen.blit(ts, ts.get_rect(centerx=W//2, y=14))
        ss = font_sub.render(
            "Swap all toads to the right side and all frogs to the left!", True, TEXT_DIM)
        screen.blit(ss, ss.get_rect(centerx=W//2, y=54))

        # n selector buttons 
        nl = font_info.render("n =", True, TEXT_DIM)
        screen.blit(nl, (self.n_btns[0][0].x-44, self.n_btns[0][0].y+9))
        for rect,val in self.n_btns:
            draw_button(screen, rect, str(val), rect.collidepoint(mx,my), val==self.n)

        # Info panel 
        ip = pygame.Rect(W//2-330, 108, 660, 44)
        draw_rounded_rect(screen, PANEL_BG, ip, 12, 1, BORDER_CLR)
        opt  = optimal_steps(self.n)
        m,s2 = divmod(int(self.elapsed), 60)
        itxt = (f"  Steps: {self.steps}   |   Optimal: {opt}"
                f"   |   Time: {m:02d}:{s2:02d}   |   n = {self.n}  ")
        isurf = font_info.render(itxt, True, TEXT_MAIN)
        screen.blit(isurf, isurf.get_rect(center=ip.center))

        # Legend
        leg_y = 166
        draw_toad(screen, W//2-200, leg_y, 15, t)
        lt = font_info.render("= Toad  (moves →)", True, TEXT_DIM)
        screen.blit(lt, (W//2-182, leg_y-8))
        draw_frog(screen, W//2+28, leg_y, 15, t)
        lf = font_info.render("= Frog  (moves ←)", True, TEXT_DIM)
        screen.blit(lf, (W//2+48, leg_y-8))

        # Auto-solve status banner
        if self.solve_status:
            sb = pygame.Rect(W//2-280, 193, 560, 30)
            draw_rounded_rect(screen, (20, 50, 30), sb, 8, 1, (40,130,70))
            sl = font_info.render(self.solve_status, True, TEXT_AUTO)
            screen.blit(sl, sl.get_rect(center=sb.center))

        # Progress bar
        goal = make_goal(self.n)
        pct  = sum(1 for a,b in zip(self.state,goal) if a==b) / len(self.state)
        br   = pygame.Rect(W//2-220, 415, 440, 10)
        draw_rounded_rect(screen, (30,38,68), br, 5)
        if pct > 0:
            fill = pygame.Rect(br.x, br.y, int(440*pct), 10)
            draw_rounded_rect(screen, (80,150,255), fill, 5)
        ps = font_info.render(f"Progress: {int(pct*100)}%", True, TEXT_DIM)
        screen.blit(ps, ps.get_rect(centerx=W//2, y=431))

        # Board
        valid_dests = set(self._valid_dests())
        empty_idx   = self.state.index('_')

        for i,(cx,cy,r) in enumerate(cells):
            piece = self.state[i]
            sel   = (self.selected == i)
            vd    = (i in valid_dests)

            if self.anim and not self.anim.done and i == empty_idx and piece == '_':
                draw_empty_cell(screen, cx, cy, r, t, vd)
                continue

            if piece == 'T':
                draw_toad(screen, cx, cy, r, t, sel, vd)
            elif piece == 'F':
                draw_frog(screen, cx, cy, r, t, sel, vd)
            else:
                draw_empty_cell(screen, cx, cy, r, t, vd)

        # Animated piece
        if self.anim and not self.anim.done:
            _,_,r = cells[0]
            if self.anim.piece == 'T':
                draw_toad(screen, self.anim.cx, self.anim.cy, r, t)
            else:
                draw_frog(screen, self.anim.cx, self.anim.cy, r, t)

        # Hint arrows
        if not self.solving:
            hint_y = self.BOARD_Y - cells[0][2] - 28
            for frm,to in legal_moves(self.state):
                if frm == self.selected or to in valid_dests:
                    cx1 = cells[frm][0]; cx2 = cells[to][0]
                    col = SEL_RING if frm==self.selected else EMPTY_RING
                    draw_arrow(screen, cx1, hint_y, cx2, hint_y, col, 2)
        else:
            # During auto-solve: show next move arrow in cyan
            if (not self.anim and
                    self.solve_step_idx < len(self.solve_path)):
                frm, to = self.solve_path[self.solve_step_idx]
                hint_y = self.BOARD_Y - cells[0][2] - 28
                draw_arrow(screen, cells[frm][0], hint_y,
                           cells[to][0],  hint_y, TEXT_AUTO, 3)

        # Labels under cells
        for i,(cx,cy,r) in enumerate(cells):
            p = self.state[i]
            if p != '_':
                lbl = font_label.render("TOAD" if p=='T' else "FROG", True,
                    (180,140,60) if p=='T' else (60,200,100))
                screen.blit(lbl, lbl.get_rect(centerx=int(cx), y=cy+r+8))

        # Action buttons
        draw_button(screen, self.btn_reset, "↺  RESTART",
                    self.btn_reset.collidepoint(mx,my))
        draw_button(screen, self.btn_undo,  "← UNDO",
                    self.btn_undo.collidepoint(mx,my))

        # Solve / Stop button
        if self.solving:
            draw_button(screen, self.btn_solve, "⏹  STOP SOLVE",
                        self.btn_solve.collidepoint(mx,my),
                        base_color=BTN_STOP, hover_color=BTN_STOP_H)
        else:
            draw_button(screen, self.btn_solve, "🤖  AUTO SOLVE",
                        self.btn_solve.collidepoint(mx,my),
                        base_color=BTN_SOLVE, hover_color=BTN_SOLVE_H)

        # Speed buttons
        spd_label = font_info.render("Speed:", True, TEXT_DIM)
        screen.blit(spd_label, (self.speed_btns[0][0].x, 580))
        for rect, idx in self.speed_btns:
            label, _ = SPEED_OPTIONS[idx]
            draw_button(screen, rect, label,
                        rect.collidepoint(mx,my),
                        active=(idx == self.auto_speed_idx))

        # Floating message
        if self.msg and self.msg_timer > 0:
            ms = font_info.render(self.msg, True, TEXT_LOSE)
            screen.blit(ms, ms.get_rect(centerx=W//2, y=558))

        # Win / Stuck overlay
        if self.won or self.stuck:
            ov = pygame.Surface((W,H), pygame.SRCALPHA)
            ov.fill((0,0,0,170)); screen.blit(ov,(0,0))

            opt = optimal_steps(self.n)
            if self.won:
                big  = font_big.render("YOU WIN!", True, TEXT_WIN)
                screen.blit(big, big.get_rect(centerx=W//2, centery=H//2-55))
                solved_by = "  [BFS Auto-Solved]" if not any(True for _ in []) else ""
                eff  = ("PERFECT — Optimal!" if self.steps==opt else
                        "GREAT!" if self.steps<=opt+2 else "Puzzle Complete!")
                sub2 = font_sub.render(
                    f"{eff}   Steps used: {self.steps}  |  Optimal: {opt}",
                    True, TEXT_MAIN)
                screen.blit(sub2, sub2.get_rect(centerx=W//2, centery=H//2+18))
            else:
                big  = font_big.render("STUCK!", True, TEXT_LOSE)
                screen.blit(big, big.get_rect(centerx=W//2, centery=H//2-55))
                sub2 = font_sub.render(
                    "No valid moves — press UNDO or RESTART", True, TEXT_MAIN)
                screen.blit(sub2, sub2.get_rect(centerx=W//2, centery=H//2+18))

            h3 = font_info.render("Press SPACE to restart", True, TEXT_DIM)
            screen.blit(h3, h3.get_rect(centerx=W//2, centery=H//2+60))

        # Controls hint
        ctrl = font_info.render(
            "Click to select/move  •  Z = undo  •  SPACE = restart  "
            "•  S = auto-solve  •  Speed buttons to adjust pace",
            True, TEXT_DIM)
        screen.blit(ctrl, ctrl.get_rect(centerx=W//2, y=H-20))

# MAIN LOOP

def main():
    game = Game()
    prev = time.time()

    while True:
        now  = time.time()
        dt   = now - prev
        prev = now
        mx, my = pygame.mouse.get_pos()

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                pygame.quit(); sys.exit()

            if event.type == pygame.KEYDOWN:
                if event.key in (pygame.K_r, pygame.K_SPACE):
                    game.stop_solve(); game.reset()
                if event.key == pygame.K_z:
                    game.undo()
                if event.key == pygame.K_s:
                    if game.solving: game.stop_solve()
                    else:            game.start_solve()

            if event.type == pygame.MOUSEBUTTONDOWN and event.button == 1:
                handled = False

                # n-size buttons
                for rect, val in game.n_btns:
                    if rect.collidepoint(mx, my):
                        game.stop_solve()
                        game.n = val
                        game.reset()
                        game._build_ui()
                        handled = True
                        break

                if not handled:
                    # Speed buttons
                    for rect, idx in game.speed_btns:
                        if rect.collidepoint(mx, my):
                            game.auto_speed_idx = idx
                            game.auto_speed     = SPEED_OPTIONS[idx][1]
                            handled = True
                            break

                if not handled:
                    if game.btn_reset.collidepoint(mx, my):
                        game.stop_solve(); game.reset()
                    elif game.btn_undo.collidepoint(mx, my):
                        game.undo()
                    elif game.btn_solve.collidepoint(mx, my):
                        if game.solving: game.stop_solve()
                        else:            game.start_solve()
                    else:
                        game.handle_click(mx, my)

        game.update(dt)
        game.draw(mx, my)
        pygame.display.flip()
        clock.tick(60)

if __name__ == "__main__":
    main()
